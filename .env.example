# Databricks connection
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-databricks-personal-access-token
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id

# ── Agent provider ───────────────────────────────────────────────────────────
# Choose one: anthropic | openai | azure_openai  (default: anthropic)
AGENT_PROVIDER=anthropic

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o                        # optional, default: gpt-4o

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name   # the deployment name in Azure AI Studio
AZURE_OPENAI_API_VERSION=2024-02-01            # optional, default: 2024-02-01

# ── Azure Bot Service (Teams integration) ────────────────────────────────────
MicrosoftAppId=your-azure-bot-app-id
MicrosoftAppPassword=your-azure-bot-app-password

# ── FastAPI endpoint (used by the Teams bot to call back) ─────────────────────
API_BASE_URL=https://your-app.databricksapps.com
