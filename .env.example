# Databricks connection
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-databricks-personal-access-token
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id

# ── Agent provider ───────────────────────────────────────────────────────────
# Choose one: anthropic | openai | azure_openai  (default: anthropic)
AGENT_PROVIDER=anthropic

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o                        # optional, default: gpt-4o

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name   # the deployment name in Azure AI Studio
AZURE_OPENAI_API_VERSION=2024-02-01            # optional, default: 2024-02-01

# ── Proactive monitoring (scheduler + Teams alerts) ───────────────────────────
# Create an Incoming Webhook in Teams: Channel → … → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

POLL_INTERVAL_MINUTES=1           # failure check cadence in minutes (job, pipeline, cluster)
LONG_RUNNING_INTERVAL_MINUTES=10  # long-running job check cadence in minutes
DIGEST_HOUR=9                     # UTC hour to send daily digest (0-23)

ALERT_FAILURE_HOURS_BACK=1        # fallback look-back on first run after fresh deploy
ALERT_LONG_RUNNING_MINUTES=120    # flag jobs running longer than this

# ── Persistent deduplication state ────────────────────────────────────────────
# JSON file that tracks last-checked timestamps and alerted IDs across restarts.
# On Databricks Apps (serverless), the filesystem is ephemeral — state resets on
# cold start, but the ALERT_FAILURE_HOURS_BACK fallback limits re-alert blast radius.
STATE_FILE_PATH=monitoring_state.json

# ── Azure Bot Service (Teams integration) ────────────────────────────────────
MicrosoftAppId=your-azure-bot-app-id
MicrosoftAppPassword=your-azure-bot-app-password

# ── FastAPI endpoint (used by the Teams bot to call back) ─────────────────────
API_BASE_URL=https://your-app.databricksapps.com
